PORT=3000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/susantedit
JWT_SECRET=change-this-to-a-64-char-random-string
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Admin bootstrap
ADMIN_EMAIL=your@gmail.com

# Firebase (project ID only — no service account needed for auth)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Cloud Messaging — Legacy Server Key (simpler than service account)
# Get from: Firebase Console → Project Settings → Cloud Messaging
#           → Cloud Messaging API (Legacy) → Server key
FIREBASE_SERVER_KEY=AAAAxxxxxxx:APA91bxxxxxxxxxxxxxxxx

# Gemini AI (optional — chat works without it using local Q&A)
GEMINI_API_KEY=

# Admin order alerts — Discord (easiest) OR Telegram (both free)
# Discord: channel gear → Integrations → Webhooks → New Webhook → copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Telegram: @BotFather → /newbot → get token, then getUpdates for chat ID  
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your@gmail.com
APP_URL=http://localhost:3000
