PORT=3000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/susantedit
JWT_SECRET=change-this-to-a-64-char-random-string
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Admin bootstrap
ADMIN_EMAIL=your@gmail.com

# Firebase (project ID only — no service account needed for auth)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Admin SDK — for FCM push notifications
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Gemini AI (optional — chat works without it using local Q&A)
GEMINI_API_KEY=

# Email (optional — tokens logged to console if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your@gmail.com
APP_URL=http://localhost:3000
