PORT=3000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-payment
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
NODE_ENV=development

# Email (optional - if not set, tokens are logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your@gmail.com

# App URL for email links
APP_URL=http://localhost:3000

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Firebase — only project ID needed (tokens verified via public JWKS endpoint, no service account required)
FIREBASE_PROJECT_ID=your-firebase-project-id
